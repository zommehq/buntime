{
  "name": "@buntime/vault",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NODE_ENV=production bun scripts/build.ts",
    "db:generate": "bun drizzle-kit generate",
    "db:migrate": "bun drizzle-kit migrate",
    "db:check": "bun drizzle-kit check",
    "db:seed": "VAULT_MASTER_KEY=dGVzdC12YXVsdC1tYXN0ZXIta2V5LTMyLWJ5dGVzISE= PGLITE_PATH=./server/pg_data bun scripts/seed.ts",
    "dev": "concurrently -n api,ui -c blue,green 'bun run dev:api' 'bun run dev:ui'",
    "dev:api": "VAULT_MASTER_KEY=dGVzdC12YXVsdC1tYXN0ZXIta2V5LTMyLWJ5dGVzISE= PGLITE_PATH=./server/pg_data bun --watch dev.ts",
    "dev:ui": "vite build --watch --sourcemap",
    "lint": "bun run lint:format && bun run lint:types",
    "lint:format": "bun biome check --write",
    "lint:types": "bun tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.6.0",
    "@opentelemetry/api": "^1.9.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@scalar/hono-api-reference": "^0.9.24",
    "@tanstack/react-query": "^5.66.5",
    "@tanstack/react-router": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.8.3",
    "hono-openapi": "^1.1.1",
    "postgres": "^3.4.5",
    "quick-lru": "^7.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.2",
    "tw-animate-css": "^1.3.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@electric-sql/pglite": "^0.3.14",
    "@iconify-json/lucide": "^1.2.95",
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "@types/bun": "^1.3.8",
    "@types/node": "^24.2.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.0",
    "tailwindcss": "^4.0.6",
    "typescript": "^5.9.3",
    "unplugin-icons": "^22.5.0",
    "vite": "^5.4.21"
  }
}
