{
  "name": "@buntime/shared",
  "description": "Shared types, utilities, and error classes for the Buntime plugin runtime",
  "version": "1.0.1",
  "imports": {
    "bun": "npm:@types/bun@^1.3.8",
    "hono": "npm:hono@^4",
    "hono/types": "npm:hono@^4/types",
    "hono/utils/http-status": "npm:hono@^4/utils/http-status",
    "ms": "npm:ms@^2"
  },
  "exports": {
    "./errors": "./src/errors.ts",
    "./logger": "./src/logger/index.ts",
    "./types": "./src/types/plugin.ts",
    "./utils/buntime-config": "./src/utils/buntime-config.ts",
    "./utils/config-validation": "./src/utils/config-validation.ts",
    "./utils/duration": "./src/utils/duration.ts",
    "./utils/glob": "./src/utils/glob.ts",
    "./utils/size": "./src/utils/size.ts",
    "./utils/static-handler": "./src/utils/static-handler.ts",
    "./utils/string": "./src/utils/string.ts",
    "./utils/worker-config": "./src/utils/worker-config.ts"
